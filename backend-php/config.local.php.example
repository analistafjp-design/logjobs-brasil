// Chave HMAC usada para assinar os JWTs (login) — gere uma própria e aleatória, por
// exemplo rodando localmente: php -r "echo bin2hex(random_bytes(32)), PHP_EOL;"
// NUNCA reaproveite o valor de exemplo abaixo em produção.
define('LOGJOBS_SECRET_KEY', 'TROQUE_ESTA_CHAVE_POR_UMA_ALEATORIA_DE_64_HEX_CHARS');

// Token exigido no header X-Admin-Token para acessar /api/admin/*.
define('ADMIN_TOKEN', 'TROQUE_ESTE_TOKEN');

// URL pública do site (usada no sitemap.xml e em textos). Ex.: https://logjobsbrasil.com.br
define('SITE_URL', 'https://logjobsbrasil.com.br');

